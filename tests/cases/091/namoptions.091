&RUN
iexpnr       = 091
runtime      = 20.
trestart     = 100.
dtmax        = 1
irandom      = 43
randthl      = 0.001
randu        = 0.01
ladaptive    = .true.
nprocx       = 2
nprocy       = 2
libm         = .true.
lrandomize   = .true.
/

&DOMAIN
itot         = 64
jtot         = 64
ktot         = 64
xlen         = 64
ylen         = 64
/

&PHYSICS
ps           = 101500.
igrw_damp    = 0
lbuoyancy    = .true.
ltempeq      = .true.
luvolflowr   = .true.
uflowrate    = 1.5
/

&DYNAMICS
ipoiss       = 0
iadv_thl     = 2
iadv_sv      = 7
/

&BC
thl_top      = 285.
BCtopT       = 2
BCxs         = 2
/

&NAMSUBGRID
lvreman      = .true.
/

&WALLS
nfcts = 12
nsolpts_u = 8192
nsolpts_v = 8192
nsolpts_w = 12288
nsolpts_c = 8192
nbndpts_u = 4096
nbndpts_v = 4096
nbndpts_w = 4096
nbndpts_c = 4096
nfctsecs_u = 4223
nfctsecs_v = 4223
nfctsecs_w = 0
nfctsecs_c = 4160
iwalltemp    = 2
/

&SCALARS
nsv          = 1
lscasrcl     = .true.
nscasrcl     = 1
/

&OUTPUT
lfielddump   = .true.
tfielddump   = 10.
fieldvars    = 'u0,v0,w0,th,s1'
lxytdump     = .true.
ltdump       = .true.
tstatsdump   = 5.
tsample      = 1.
/

&INPS
zsize        = 64
u0           = 1.5
thl0         = 290.
facT         = 295
xSb          = 32
ySb          = 0
zSb          = 3
xSe          = 32
ySe          = 64
zSe          = 3
SSl          = 1
sigSl        = 0.5
stl_file     = geom.091.STL
/
